# Copy to .env (gitignored) for local development.
# In CI, set these as GitHub Actions secrets instead.

SUNSYNK_USERNAME=you@example.com
SUNSYNK_PASSWORD=your-sunsynk-connect-password

# Paste the entire service-account JSON key file contents on ONE line
# (or use single quotes around a multi-line value). Not a file path.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","client_email":"...","private_key":"..."}

# The long string in your Sheet URL between /d/ and /edit.
GOOGLE_SHEET_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz0123456789ABCDE
