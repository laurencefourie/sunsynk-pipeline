# Streamlit Cloud secrets template.
#
# Local development: leave this file alone — app.py reads from .env via python-dotenv.
# Streamlit Cloud: copy this content into the "Secrets" box at
# https://share.streamlit.io/ (Manage app → Settings → Secrets),
# fill in real values, save. They get injected as st.secrets at runtime.
#
# The format below is TOML. The service-account JSON is wrapped in triple quotes
# so you can paste the whole multi-line JSON file unescaped.

SUNSYNK_USERNAME = "you@example.com"
SUNSYNK_PASSWORD = "your-sunsynk-password"
GOOGLE_SHEET_ID = "1lC5N2BWxO9tYNFWb-tvWlG2NBP_MDxv06zfbyiGf5JI"
GOOGLE_SERVICE_ACCOUNT_JSON = '''{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"sunsynk-writer@...iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}'''
